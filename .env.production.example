# Arquivo de exemplo para .env de produção
# Copie este arquivo para .env e ajuste os valores

APP_NAME="Hub Recursos Educacionais"
APP_ENV=production
APP_KEY=base64:GERAR_COM_php_artisan_key:generate
APP_DEBUG=false
APP_URL=http://SEU_IP_DA_EC2

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hub_recursos
DB_USERNAME=hub_user
DB_PASSWORD=SUA_SENHA_SEGURA_AQUI

# Cache e Session
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=sync

# Gemini API
GEMINI_API_KEY=SUA_CHAVE_GEMINI_API_AQUI
